# Optional API/WebSocket base when the SPA is served from a different host than Node (e.g. chat subdomain).
# If unset, the app uses the same origin as the page — configure nginx/Caddy to proxy /ws and /api to Node.
# Set VITE_WS_ORIGIN=https://chat.bahuckel.com only after chat.* DNS resolves.
# VITE_WS_ORIGIN=https://chat.bahuckel.com

