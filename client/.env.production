# Optional: only set when chat.* DNS exists and API is on a different host than this static site.
# Leave unset to use the same hostname as the page (nginx proxies /ws + /api to Node). Avoids
# ERR_NAME_NOT_RESOLVED when https://chat.bahuckel.com is not in DNS yet.
# VITE_WS_ORIGIN=https://chat.bahuckel.com
